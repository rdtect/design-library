{
  "name": "@rdtect/ui",
  "version": "0.1.0",
  "description": "rdtect UI component library — Svelte 5 + design tokens",
  "type": "module",
  "svelte": "./src/lib/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "svelte": "./src/lib/index.ts",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist/", "src/"],
  "scripts": {
    "build": "svelte-package -i src/lib",
    "dev": "svelte-package -i src/lib --watch",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@rdtect/tokens": "workspace:*",
    "@rdtect/tailwind-preset": "workspace:*",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@testing-library/svelte": "*",
    "happy-dom": "*",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "*"
  },
  "keywords": ["svelte", "ui", "components", "rdtect"],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
